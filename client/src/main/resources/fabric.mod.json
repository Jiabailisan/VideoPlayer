{
	"schemaVersion": 1,
	"id": "videoplayer_client",
	"version": "${version}",
	"name": "VideoPlayer-Client",
	"description": "Client renderer, VLC playback, GUI, and controls for VideoPlayer.",
	"authors": [
		"squi2rel",
		"ported-by-codex"
	],
	"contact": {
		"sources": "https://github.com/squi2rel/VideoPlayer/"
	},
	"license": "GPL-3.0",
	"icon": "assets/videoplayer/icon.png",
